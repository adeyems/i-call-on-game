{
  "name": "i-call-on",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:worker": "npm --workspace apps/worker run build",
    "deploy:web": "npm --workspace apps/web run deploy",
    "deploy:worker": "npm --workspace apps/worker run deploy",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "test": "npm --workspaces --if-present run test"
  }
}
